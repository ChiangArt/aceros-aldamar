function product(
  params: Omit<CatalogProduct, "id" | "technical"> & {
    id?: string;
    technical?: string[];
  },
): CatalogProduct {
  const id = params.id ?? slug(`${params.categoryId}-${params.name}`);
  return { technical: [], ...params, id };
}

