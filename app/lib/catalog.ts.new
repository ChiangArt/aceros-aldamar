export type CatalogCategoryId =
  | "construccion"
  | "tubos-con-costura"
  | "perfiles"
  | "ejes"
  | "planchas-lac"
  | "planchas-especiales"
  | "bobinas-y-planchas"
  | "tubos-sin-costura";

export type DimensionTable = {
  title: string;
  note?: string;
  columns: string[];
  rows: Array<Array<string | number>>;
};

export type CatalogProduct = {
  id: string;
  categoryId: CatalogCategoryId;
  name: string;
  shortDescription: string;
  description: string;
  technical?: string[];
  presentation: string[];
  uses: string[];
  dimensions: DimensionTable[];
  standards?: string[];
  datasheet?: { label?: string; href: string } | null;
  image: string;
  imageHover: string;
  tags?: string[];
};

export type CatalogCategory = {
  id: CatalogCategoryId;
  name: string;
  description: string;
  image: string;
  imageHover: string;
};

function slug(input: string) {
  return input
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
}

