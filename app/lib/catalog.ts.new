export function getCategoryById(id: string) {
  return catalogCategories.find((c) => c.id === id) ?? null;
}

export function getProductById(id: string) {
  return catalogProducts.find((p) => p.id === id) ?? null;
}

export function getProductsByCategory(categoryId: CatalogCategoryId) {
  return catalogProducts.filter((p) => p.categoryId === categoryId);
}
